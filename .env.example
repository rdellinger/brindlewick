# ── Supabase ────────────────────────────────────────────────────────────────
# From your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, NEVER expose to the browser
# Used by admin routes and the cron function
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Anthropic ────────────────────────────────────────────────────────────────
# From console.anthropic.com → API Keys
# Used for the natural-language command parser and NPC dialogue
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Model to use for NLU (haiku is fast and cheap; upgrade to sonnet for richer dialogue)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Admin Auth ───────────────────────────────────────────────────────────────
# A secret string used to verify admin sessions (set to any long random string)
# Generate with: openssl rand -base64 32
ADMIN_SECRET=your-admin-secret-here

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Cron Security ────────────────────────────────────────────────────────────
# Secret sent in the Authorization header when Vercel Cron calls /api/cron/advance-world
# Set this in both Vercel env vars and your cron configuration
CRON_SECRET=your-cron-secret-here
