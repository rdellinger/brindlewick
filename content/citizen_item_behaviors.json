    // ── Agnes Perkins ─────────────────────────────────────────────────────────
    // Agnes keeps honey at her home. She'll offer it to the player once trusted,
    // and on tick she might bring a jar to Marigold as a peace offering.

    {
      "citizen_id": "agnes_perkins",
      "trigger_type": "world_tick",
      "trigger_condition": "at_location:perkins_cider_house",
      "action_type": "pick_up",
      "item_id": "perkins_alpine_honey",
      "once_only": false,
      "dialogue_hint": "Agnes takes a jar of her alpine honey from the shelf.",
      "sort_order": 0
    },
    {
      "citizen_id": "agnes_perkins",
      "trigger_type": "on_talk",
      "trigger_condition": "trust >= 3",
      "action_type": "offer_to_player",
      "item_id": "perkins_alpine_honey",
      "once_only": true,
      "dialogue_hint": "Agnes holds out the small honey jar. 'Marigold's been asking after this. Would you mind taking it over?'",
      "sort_order": 0
    },
    {
      "citizen_id": "agnes_perkins",
      "trigger_type": "on_ask",
      "trigger_condition": "holding:perkins_alpine_honey",
      "action_type": "give_to_player",
      "item_id": "perkins_alpine_honey",
      "once_only": true,
      "dialogue_hint": "Agnes nods and presses the honey into your hands. 'Tell her it's from the high meadow. She'll know.'",
      "sort_order": 0
    },
    {
      "citizen_id": "agnes_perkins",
      "trigger_type": "world_tick",
      "trigger_condition": "at_location:copper_kettle_bakery",
      "action_type": "give_to_citizen",
      "item_id": "perkins_alpine_honey",
      "target_citizen_id": "marigold_osei",
      "once_only": true,
      "dialogue_hint": "Agnes quietly leaves a jar of honey on the bakery counter for Marigold. An old kindness, offered without fanfare.",
      "sort_order": 10
    },

